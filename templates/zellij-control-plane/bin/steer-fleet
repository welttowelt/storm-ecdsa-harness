#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT/bin/env.sh"

delivered_file="$STORM_RUNTIME_DIR/steer-delivered.tsv"

usage() {
  cat <<'TEXT'
usage:
  ./bin/steer-fleet status
  ./bin/steer-fleet dispatch [--dry-run]

Reads pending dispatch packets and types them into the matching live agent pane.
It never submits, writes winner sentinels, kills jobs, starts compute, or passes
secrets.
TEXT
}

dry_run=0

init_runtime() {
  mkdir -p "$STORM_RUNTIME_DIR"
  if [[ ! -f "$delivered_file" ]]; then
    printf '# time\tdispatch_id\tworker\tpane\tpane_id\tstatus\n' >"$delivered_file"
  fi
}

require_zellij() {
  if [[ -z "${ZELLIJ:-}" ]]; then
    printf 'Not inside zellij. Attach to %s first.\n' "$STORM_SESSION" >&2
    exit 64
  fi
}

pane_for_worker() {
  case "$1" in
    auditor) printf 'auditor-codex' ;;
    pua-pip) printf 'pua-pip-codex' ;;
    researcher) printf 'research-codex' ;;
    source-proof) printf 'source-proof-codex' ;;
    validator) printf 'validator-codex' ;;
    pods-manager) printf 'pods-manager-codex' ;;
    wallbreaker-lead) printf 'wallbreaker-lead-codex' ;;
    wallbreaker-shadow) printf 'wallbreaker-shadow-codex' ;;
    claude-waffle-lab) printf 'waffle-lab-claude' ;;
    claude-laser-spatula) printf 'laser-spatula-claude' ;;
    claude-research-sommelier) printf 'research-sommelier-claude' ;;
    worker|workers) printf 'worker-codex' ;;
    boss) printf 'boss-codex' ;;
    *) return 1 ;;
  esac
}

pane_id_by_name() {
  local name="$1"
  zellij action list-panes | awk -v name="$name" 'NR > 1 && $3 == name { print $1; exit }'
}

pane_busy() {
  local pane_id="$1" screen
  screen="$(zellij action dump-screen --pane-id "$pane_id" 2>/dev/null || true)"
  if printf '%s\n' "$screen" | rg -q 'Working|background terminal running|esc to interrupt|still thinking|Brewing|Cascading|Germinating|Computing|Choreographing|Jitterbugging|Deliberating|Thinking|Herding|Pondering'; then
    return 0
  fi
  return 1
}

submit_queued_message_if_needed() {
  local pane_id="$1" screen
  screen="$(zellij action dump-screen --pane-id "$pane_id" 2>/dev/null || true)"
  if printf '%s\n' "$screen" | rg -q 'Press up to edit queued messages'; then
    zellij action write --pane-id "$pane_id" 13
    sleep 0.6
  fi
}

record_delivery() {
  local dispatch_id="$1" worker="$2" pane="$3" pane_id="$4" status="$5"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$(date '+%Y-%m-%d %H:%M:%S %Z')" \
    "$dispatch_id" "$worker" "$pane" "$pane_id" "$status" >>"$delivered_file"
}

pending_dispatches() {
  awk -F '\t' 'NR > 1 && $2 == "pending" { print }' "$STORM_DISPATCH_LEDGER"
}

prompt_for_dispatch() {
  local id="$1" target="$2" owner="$3" title="$4" note="$5"
  cat <<TEXT
DISPATCH $id for $target from $owner.

Work from $STORM_FLEET_ROOT. Start now; do not wait for another boss prompt.

Title:
$title

Task:
$note

Required discipline:
- Run Bluesky, Redsky, RCI, PUA, or PIP as appropriate for the role.
- Produce one evidence-backed ACK, NACK, wait, done, route_attempt, worker_attempt, or hard_nack.
- Close the dispatch with ./bin/dispatch close $id "summary..." when state changes.
- Keep no_submit_ack=yes explicit.
- Do not submit, write winner sentinels, print/log/pass secrets, or bypass local policy gates.
TEXT
}

status() {
  require_zellij
  init_runtime
  printf 'fleet steering\n'
  printf 'dispatch ledger: %s\n\n' "$STORM_DISPATCH_LEDGER"
  printf 'pending dispatches:\n'
  if ! pending_dispatches | awk -F '\t' '{ printf "  %s -> %s %s\n", $1, $3, $5 }' | rg '.'; then
    printf '  none\n'
  fi
  printf '\npane map:\n'
  for worker in auditor pua-pip researcher source-proof validator pods-manager wallbreaker-lead wallbreaker-shadow claude-waffle-lab claude-laser-spatula claude-research-sommelier worker; do
    pane="$(pane_for_worker "$worker")"
    pane_id="$(pane_id_by_name "$pane")"
    if [[ -z "$pane_id" ]]; then
      printf '  %-28s %-24s missing\n' "$worker" "$pane"
    elif pane_busy "$pane_id"; then
      printf '  %-28s %-24s %s busy\n' "$worker" "$pane" "$pane_id"
    else
      printf '  %-28s %-24s %s idle\n' "$worker" "$pane" "$pane_id"
    fi
  done
}

dispatch() {
  require_zellij
  init_runtime
  local sent=0 skipped=0
  while IFS=$'\t' read -r id status_field target owner title note; do
    [[ -n "${id:-}" ]] || continue
    if ! pane="$(pane_for_worker "$target")"; then
      printf 'skip %s: no pane mapping for target=%s\n' "$id" "$target"
      skipped="$((skipped + 1))"
      continue
    fi
    pane_id="$(pane_id_by_name "$pane")"
    if [[ -z "$pane_id" ]]; then
      printf 'skip %s: pane missing: %s\n' "$id" "$pane"
      skipped="$((skipped + 1))"
      continue
    fi
    if pane_busy "$pane_id"; then
      printf 'skip %s: pane busy: %s (%s)\n' "$id" "$pane" "$pane_id"
      record_delivery "$id" "$target" "$pane" "$pane_id" busy
      skipped="$((skipped + 1))"
      continue
    fi
    prompt="$(prompt_for_dispatch "$id" "$target" "$owner" "$title" "$note")"
    printf 'send %s -> %s (%s)\n' "$id" "$pane" "$pane_id"
    if [[ "$dry_run" -eq 1 ]]; then
      printf '%s\n' "$prompt" | sed 's/^/  /'
    else
      zellij action write-chars --pane-id "$pane_id" "$prompt"
      sleep 0.4
      zellij action send-keys --pane-id "$pane_id" Enter
      sleep 0.4
      submit_queued_message_if_needed "$pane_id"
      record_delivery "$id" "$target" "$pane" "$pane_id" sent
    fi
    sent="$((sent + 1))"
  done < <(pending_dispatches)
  printf 'fleet steering complete: sent=%s skipped=%s\n' "$sent" "$skipped"
}

cmd="${1:-status}"
shift || true
for arg in "$@"; do
  case "$arg" in
    --dry-run) dry_run=1 ;;
    *) usage >&2; exit 64 ;;
  esac
done

case "$cmd" in
  status) status ;;
  dispatch) dispatch ;;
  help|-h|--help) usage ;;
  *) usage >&2; exit 64 ;;
esac
