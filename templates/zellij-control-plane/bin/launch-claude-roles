#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT/bin/env.sh"

if [[ -z "${ZELLIJ:-}" ]]; then
  printf 'Not inside zellij. Start the board with:\n' >&2
  printf '  cd %s && ./bin/start-zellij\n' "$STORM_FLEET_ROOT" >&2
  exit 64
fi

CLAUDE_BIN="$(command -v claude)"

tab_id_by_name() {
  local name="$1"
  zellij action list-tabs | awk -v name="$name" 'NR > 1 && $3 == name { print $1; exit }'
}

pane_exists() {
  local name="$1"
  zellij action list-panes | awk -v name="$name" 'NR > 1 && $3 == name { found = 1 } END { exit found ? 0 : 1 }'
}

new_claude_pane() {
  local tab="$1" pane="$2" session_name="$3" prompt="$4" tab_id
  if pane_exists "$pane"; then
    printf 'claude pane exists: %s\n' "$pane"
    return
  fi
  tab_id="$(tab_id_by_name "$tab")"
  if [[ -z "$tab_id" ]]; then
    printf 'missing zellij tab: %s\n' "$tab" >&2
    exit 66
  fi
  printf 'creating claude pane: tab=%s pane=%s\n' "$tab" "$pane"
  zellij action new-pane \
    --tab-id "$tab_id" \
    --name "$pane" \
    --cwd "$STORM_FLEET_ROOT" \
    -- "$CLAUDE_BIN" \
      --dangerously-skip-permissions \
      --effort max \
      --model opus \
      --name "$session_name" \
      "$prompt"
}

common_guardrails='Do not submit, write winner sentinels, leak secrets, pass provider credentials on command lines, print account/payment details, kill jobs, lease paid compute, open spend, or launch worker-island unless the current repo policy gates explicitly allow it. Keep no_submit_ack=yes in every output.'

new_claude_pane waffle-lab waffle-lab-claude "STORM Waffle Lab" \
  "You are claude-waffle-lab, a long-context deep engineer. Work from $STORM_FLEET_ROOT. Read docs/claude-worker-loops.md, docs/control-plane.md, docs/current-findings.md, ./bin/wallbreaker-brief, state/fleet-policy.env, workers.tsv, and ./bin/check-gates output. Connect research, source-proof, provider, validator, and wallbreaker evidence into one executable route_attempt, worker_attempt, or hard_nack. Use strict Bluesky -> Redsky -> PUA -> PIP loops and do not stop after a first NACK. $common_guardrails"

new_claude_pane waffle-lab laser-spatula-claude "STORM Laser Spatula" \
  "You are claude-laser-spatula, the adversarial long-context deep engineer. Work from $STORM_FLEET_ROOT. Read docs/claude-worker-loops.md, ./bin/wallbreaker-brief, docs/current-findings.md, state/fleet-policy.env, and ./bin/check-gates output. Falsify the current lead route fast or produce one materially different alternate with exact source, evidence label, validator, and stop condition. Use Bluesky -> Redsky -> PUA -> PIP. $common_guardrails"

new_claude_pane research-vault research-sommelier-claude "STORM Research Sommelier" \
  "You are claude-research-sommelier, the dedicated long-context researcher. Work from $STORM_FLEET_ROOT. Read docs/claude-worker-loops.md, docs/control-plane.md, docs/current-findings.md, state/skill-registry.tsv, templates/research-packet.md, and ./bin/check-gates output. Digest large context one bounded batch at a time, audit between batches, and convert research into source mappings, hashes, q/T economics, proof obligations, falsifiers, and handoffs. Use Bluesky -> Redsky, PUA after repeated misses, and PIP when research becomes vague. $common_guardrails"

zellij action list-panes
